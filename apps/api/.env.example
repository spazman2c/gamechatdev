# ===========================================
# Nexora API — Environment Variables
# Copy to .env and fill in your values
# ===========================================

NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://nexora:nexora_dev_password@localhost:5432/nexora

# Redis
REDIS_URL=redis://:nexora_redis_password@localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_to_a_random_32_char_string_minimum
JWT_REFRESH_SECRET=change_me_to_a_different_random_32_char_string

# LiveKit (voice/video)
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Email (MailHog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@nexora.app

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:3000

# Storage (optional for local dev, files served locally)
# S3_ENDPOINT=https://your-r2-endpoint
# S3_BUCKET=nexora-media
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your_key
# S3_SECRET_ACCESS_KEY=your_secret
